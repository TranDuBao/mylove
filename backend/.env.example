# Server Port
PORT=5000

# MongoDB Connection String (leave blank to run in JSON file-based database fallback mode)
MONGODB_URI=mongodb://localhost:27017/love_db

# JWT secret key for secure sessions
JWT_SECRET=super_secret_romantic_key_change_me_in_production

# Cloudinary Config (Optional: If left empty, site will fall back to local disk storage in backend/uploads/)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Default admin setup (will be created automatically if no admins exist)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=love123
